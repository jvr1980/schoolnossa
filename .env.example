# Google Cloud Storage Configuration
GCS_BUCKET_NAME=schoolnossa-berlin
GCS_PROJECT_ID=schoolnossa

# Optional: Path to service account key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Crawler Configuration
MAX_CONCURRENT_REQUESTS=3
MAX_PAGES=None  # Set to a number to limit pages, or None/leave empty for all pages

# Kita Navigator Specific
KITA_NAVIGATOR_BASE_URL=https://kita-navigator.berlin.de/einrichtungen?input=&betb=10-2025&einfacheSuche=true&entfernung=50&seite=1&index=0

# Gemini API Key - Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# School Scraping Configuration
# Apify API Token - Get from https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Google Places API Key - Get from https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Maximum results per search for school scraping
MAX_RESULTS_PER_SEARCH=100

# Whether to fetch detailed place information (costs more API calls)
FETCH_PLACE_DETAILS=true
